{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "autoupdate": true,
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "server": {
    "port": 4096
  },
  "tools": {
    "write": true,
    "edit": true,
    "bash": true,
    "read": true
  },
  "permission": {
    "edit": "allow",
    "bash": "ask"
  },
  "provider": {
    "anthropic": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 30000,
        "setCacheKey": true
      }
    },
    "openai": {
      "options": {
        "timeout": 600000
      }
    },
    "google": {
      "options": {
        "timeout": 600000
      }
    }
  },
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    "docs/guidelines.md",
    ".opencode/instructions/*.md"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.github.com/mcp",
      "oauth": {},
      "enabled": true,
      "timeout": 10000
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {},
      "enabled": true,
      "timeout": 10000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 5000
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 5000
    },
    "agent-memory": {
      "type": "remote",
      "url": "https://remembr.dev/api/v1/mcp",
      "headers": {
        "Authorization": "Bearer ${env:AGENT_MEMORY_TOKEN}"
      },
      "enabled": false,
      "timeout": 10000
    }
  },
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices, security, and performance",
      "model": "openai/gpt-5.4",
      "prompt": "You are a senior code reviewer. Focus on:\n- Security vulnerabilities\n- Performance issues\n- Code maintainability\n- Best practices and patterns\n- Error handling\nProvide constructive feedback with specific suggestions.",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "planner": {
      "description": "Creates implementation plans without making changes",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "You are a technical architect. Create detailed implementation plans with:\n- Step-by-step breakdown\n- Files to modify/create\n- Dependencies and prerequisites\n- Risk assessment\n- Testing strategy\nDo not write code or make changes.",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "memory-manager": {
      "description": "Manages memory storage and retrieval for the project",
      "model": "openai/gpt-5.4-mini",
      "prompt": "You manage project memory using Agent Memory Commons. Store and retrieve:\n- Project context and decisions\n- Code patterns and conventions\n- User preferences\n- Session history\nUse the agent-memory MCP server when available.",
      "tools": {
        "read": true,
        "bash": true
      }
    }
  },
  "plugin": [],
  "formatter": {
    "prettier": {
      "disabled": false
    },
    "black": {
      "disabled": false
    },
    "gofmt": {
      "disabled": false
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "vendor/**",
      "*.log"
    ]
  },
  "share": "manual"
}