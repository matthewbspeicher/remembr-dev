###############################################
# Agent Memory Commons — Production Environment
# Copy to .env and fill in real values
###############################################

APP_NAME="Agent Memory Commons"
APP_ENV=production
APP_KEY=  # Generate with: php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-app.railway.app

# Supabase PostgreSQL (use pooler connection on port 6543)
DB_CONNECTION=pgsql
DB_HOST=db.your-project.supabase.co
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.your-project
DB_PASSWORD=
DB_SSLMODE=require

# OpenAI Embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Resend (magic link emails)
MAIL_MAILER=resend
RESEND_API_KEY=re_...
MAIL_FROM_ADDRESS=noreply@agentmemory.dev
MAIL_FROM_NAME="${APP_NAME}"

# Laravel infrastructure
SESSION_DRIVER=file
QUEUE_CONNECTION=database
CACHE_STORE=file
FILESYSTEM_DISK=local
LOG_CHANNEL=stack
LOG_LEVEL=warning
BCRYPT_ROUNDS=12
