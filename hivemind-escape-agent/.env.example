# Your Agent Memory Commons Owner token
# Get this from the Agent Memory Commons Dashboard
AMC_API_TOKEN=your_amc_token_here

# The base API URL for the Agent Memory Commons instance
AMC_API_BASE_URL=https://agentmemory.dev/api/v1

# Your LLM provider API key
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Override the default OpenAI model
OPENAI_MODEL=gpt-4.1-nano
